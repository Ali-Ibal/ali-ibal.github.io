<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Poetry - Iqbal Revival</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Georgia', serif;
            background-color: #0a0a0a;
            color: #ffffff;
            line-height: 1.6;
        }

        /* Header */
        header {
            background-color: #0a0a0a;
            padding: 20px;
            border-bottom: 2px solid #ffd700;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
        }

        .logo {
            color: #ffd700;
            font-size: 28px;
            font-weight: bold;
            text-decoration: none;
        }

        nav ul {
            list-style: none;
            display: flex;
            gap: 30px;
            flex-wrap: wrap;
        }

        nav a {
            color: #ffffff;
            text-decoration: none;
            font-size: 16px;
            transition: color 0.3s;
        }

        nav a:hover {
            color: #ffd700;
        }

        /* Hero Section */
        .hero {
            text-align: center;
            padding: 80px 20px;
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 100%);
        }

        .hero h1 {
            color: #ffd700;
            font-size: 48px;
            margin-bottom: 20px;
        }

        .hero p {
            color: #cccccc;
            font-size: 20px;
            max-width: 600px;
            margin: 0 auto;
        }

        /* Poetry Section */
        .poetry-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        .poem-card {
            background: linear-gradient(135deg, #1a1a1a 0%, #2a2a2a 100%);
            border-left: 4px solid #ffd700;
            padding: 30px;
            margin-bottom: 40px;
            border-radius: 0 10px 10px 0;
            transition: transform 0.3s;
        }

        .poem-card:hover {
            transform: translateX(10px);
        }

        .poem-title {
            color: #ffd700;
            font-size: 24px;
            margin-bottom: 15px;
            font-weight: bold;
        }

        .poem-content {
            color: #e0e0e0;
            font-size: 18px;
            line-height: 2;
            margin-bottom: 20px;
            font-style: italic;
        }

